NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_MOCK_ISSUER_URL=http://localhost:3001
# Set true after deploying pool v9 (operator-signed Merkle roots)
NEXT_PUBLIC_POOL_SIGNED_ROOT=true
# Set true after deploying pool v10 (on-chain AttestProtocol KYC attestation gate).
# When true the UI enrolls wallets via the issuer and threads the attestation UID
# into deposit/withdraw, which the pool verifies on-chain (cross-contract).
NEXT_PUBLIC_POOL_KYC_ATTEST=true
